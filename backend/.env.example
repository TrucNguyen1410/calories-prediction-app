# ==== HealthAI Backend — mẫu biến môi trường ====
# Sao chép file này thành `.env` và điền giá trị thật. KHÔNG commit file .env.

# Cổng server (Render tự cấp PORT trong production)
PORT=3000

# Chuỗi kết nối MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Khóa bí mật ký JWT — đặt chuỗi ngẫu nhiên đủ mạnh
JWT_SECRET=thay_bang_chuoi_bi_mat_ngau_nhien

# API key Groq (LLM cho chat / phân tích ảnh / thực đơn)
GROQ_API_KEY=

# API key Resend (gửi email đóng góp ý kiến)
RESEND_API_KEY=

# Email nhận góp ý (tùy chọn — mặc định trong code nếu bỏ trống)
FEEDBACK_RECIPIENT=
